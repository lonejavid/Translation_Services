# Copy to .env and set values (never commit real .env with secrets)
# Get HF token: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here
COQUI_TOS_AGREED=1

# --- Server / security ---
# Comma-separated list of allowed CORS origins (default: localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# Max concurrent pipeline jobs before returning 429
# MAX_CONCURRENT_JOBS=5
# Auto-delete cache files older than N hours (default: 168 = 7 days)
# CACHE_TTL_HOURS=168
# Minimum free disk space before rejecting new jobs (GB)
# MIN_FREE_DISK_GB=2.0
# Override cache directory (default: server/cache/)
# CACHE_DIR=/mnt/storage/translation-cache
# Max subtitle segments per PUT request
# MAX_SUBTITLE_SEGMENTS=5000
# Max chars per subtitle text field
# MAX_SUBTITLE_TEXT_LEN=2000

# Translation backend: google (default, deep-translator → Google; needs internet) or local (PyTorch NLLB/IndicTrans2)
# TRANSLATION_BACKEND=google
# GOOGLE_TRANSLATE_CHUNK=8
# GOOGLE_TRANSLATE_DELAY_S=0.25
#
# Translation quality guard (repetition / length / Hindi script). Google path retries bad lines then source fallback.
# TRANSLATION_VALIDATION_ENABLED=1
# TRANSLATION_VALIDATION_STRICT=0
#
# Local only — TRANSLATION_ENGINE=nllb | indictrans2, NLLB_MODEL_NAME=...

# Dub export quality (final mix)
# AUDIO_FORMAT=mp3
# AUDIO_BITRATE=320
# AUDIO_ENHANCE=0
# TTS_DUB_MASTER_SAMPLE_RATE=48000
#
# Hindi dub: Microsoft Edge neural TTS (natural; needs internet). Set 0 to use local Coqui/MMS only.
# TTS_USE_EDGE=1
# VOICE_MALE=hi-IN-MadhurNeural
# VOICE_FEMALE=hi-IN-SwaraNeural
# VOICE_DEFAULT=hi-IN-MadhurNeural
# EDGE_TTS_VOICE_HI=hi-IN-SwaraNeural
# EDGE_TTS_VOICE_HI=hi-IN-MadhurNeural
#
# Gender hint (reference clip) + clone verification
# GENDER_CONFIDENCE_THRESHOLD=0.7
# GENDER_CLONE_VERIFY=1
# GENDER_CLONE_VERIFY_MIN_CONF=0.55
# Optional: EDGE_TTS_RATE=+0%  EDGE_TTS_PITCH=+0Hz
#
# XTTS voice clone from YouTube audio (server/cache/{md5}_xtts_ref.wav). run.sh defaults TTS_HI_USE_XTTS_CLONE=0 (Edge-first).
# TTS_HI_USE_XTTS_CLONE=1
#
# Hindi XTTS decoding (optional; steadier defaults for hi)
# XTTS_HI_SPLIT_SENTENCES=1
# XTTS_HI_TEMPERATURE=0.7
# XTTS_HI_LENGTH_PENALTY=1.0
# XTTS_HI_REPETITION_PENALTY=2.0
# XTTS_HI_TOP_K=50
# XTTS_HI_TOP_P=0.95
#
# Hindi: default minimal text path (no clean_text_for_tts / no clause splits). HINDI_RAW_MODE=0 restores full clean + splits (or HINDI_TTS_RAW_MODE=1 alone).
# HINDI_RAW_MODE=1
# HINDI_TTS_RAW_MODE=0
# HINDI_CORRUPTION_CHECK=1
# HINDI_USE_EDGE_FALLBACK=0
# HINDI_TTS_ENGINE=edge
# HINDI_TTS_ENGINE=xtts
# HINDI_TTS_ENGINE=mms
# TTS_HINDI_CROSSFADE_MS=75
# TTS_HINDI_DEBUG=0
# DISABLE_VOICE_REF_EXTRACTION=0
# VOICE_REF_DURATION_SEC=12
# VOICE_REF_VAD_MODE=1
# VOICE_REF_MIN_SPEECH_SEC=2.0
# VOICE_REF_USE_NOISEREDUCE=0
# VOICE_REF_OUTPUT_SR=24000
